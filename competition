    // ==========================================
    // AI EXTRACTION (GEMINI API - FREE TIER)
    // ==========================================
    document.getElementById('extractBtn').addEventListener('click', async () => {
        const text = document.getElementById('whatsappInput').value.trim();
        if (!text) return alert('Paste a message first!');
        
        const btn = document.getElementById('extractBtn');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Extracting...';
        btn.disabled = true;

        try {
            // Try Gemini API first (requires API key in localStorage)
            const apiKey = localStorage.getItem('klyrr_gemini_key');
            let extracted = null;

            if (apiKey) {
                const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: `Extract competition/hackathon details. Return ONLY valid JSON: {"title":"","organizer":"","deadline":"","prize":"","location":"","applyUrl":"","description":"","tags":[],"timeline":"","teamSize":""}. Valid tags: coding,design,science,business,advanced,intermediate,beginner,open,hybrid,online,offline. Message:\n${text}` }] }]
                    })
                });
                const data = await res.json();
                const content = data.candidates?.[0]?.content?.parts?.[0]?.text || '{}';
                const match = content.match(/\{[\s\S]*\}/);
                if (match) extracted = JSON.parse(match[0]);
            }

            if (!extracted) {
                // Fallback: Local regex parser
                extracted = localParser(text);
            }

            // Populate form
            document.getElementById('exTitle').value = extracted.title || '';
            document.getElementById('exOrganizer').value = extracted.organizer || '';
            document.getElementById('exDeadline').value = extracted.deadline || '';
            document.getElementById('exPrize').value = extracted.prize || '';
            document.getElementById('exLocation').value = extracted.location || '';
            document.getElementById('exTimeline').value = extracted.timeline || '';
            document.getElementById('exTeamSize').value = extracted.teamSize || '';
            document.getElementById('exApplyUrl').value = extracted.applyUrl || '';
            document.getElementById('exDescription').value = extracted.description || '';
            document.getElementById('exTags').value = (extracted.tags || []).join(', ');
            
            document.getElementById('extractedForm').classList.remove('hidden');
        } catch (err) {
            console.error(err);
            const extracted = localParser(text);
            document.getElementById('exTitle').value = extracted.title || '';
            document.getElementById('exOrganizer').value = extracted.organizer || '';
            document.getElementById('exDeadline').value = extracted.deadline || '';
            document.getElementById('exPrize').value = extracted.prize || '';
            document.getElementById('exLocation').value = extracted.location || '';
            document.getElementById('exTimeline').value = extracted.timeline || '';
            document.getElementById('exTeamSize').value = extracted.teamSize || '';
            document.getElementById('exApplyUrl').value = extracted.applyUrl || '';
            document.getElementById('exDescription').value = extracted.description || '';
            document.getElementById('exTags').value = (extracted.tags || []).join(', ');
            document.getElementById('extractedForm').classList.remove('hidden');
        }

        btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Extract with AI';
        btn.disabled = false;
    });

    // LOCAL PARSER (Fallback if no API key)
    function localParser(text) {
        const r = { title: '', organizer: '', deadline: '', prize: '', location: '', applyUrl: '', description: '', tags: [], timeline: '', teamSize: '' };
        
        const urlM = text.match(/https?:\/\/[^\s<>"{}|\\^`\]]+/);
        if (urlM) r.applyUrl = urlM[0];
        
        const boldM = text.match(/\*([^*]+)\*/);
        if (boldM) r.title = boldM[1].replace(/[🔥💰📅📍🔗💻🏆⚡🎯📋🚀]/g, '').trim();
        
        const prizeM = text.match(/[💰🏆].*?[:\-]\s*(.+?)[\n|$]/i) || text.match(/prize[:\-]\s*(.+?)[\n|$]/i);
        if (prizeM) r.prize = prizeM[1].trim();
        
        const dateM = text.match(/(\d{1,2})\s*(st|nd|rd|th)?\s*(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec|january|february|march|april|may|june|july|august|september|october|november|december)[,]?\s*(\d{4})/i);
        if (dateM) r.deadline = `${dateM[3].charAt(0).toUpperCase() + dateM[3].slice(1,3)} ${dateM[1]}, ${dateM[4]}`;
        
        const locM = text.match(/[📍].*?[:\-]\s*(.+?)[\n|$]/i) || text.match(/location[:\-]\s*(.+?)[\n|$]/i);
        if (locM) r.location = locM[1].trim();

        const teamM = text.match(/team[:\-]\s*(.+?)[\n|$]/i) || text.match(/(\d[\s-]*\d?\s*members?)/i);
        if (teamM) r.teamSize = teamM[1].trim();

        const lower = text.toLowerCase();
        if (lower.match(/cod|programm|hackathon|develop/)) r.tags.push('coding');
        if (lower.match(/design|ui|ux|figma/)) r.tags.push('design');
        if (lower.match(/science|research|nasa|space/)) r.tags.push('science');
        if (lower.match(/business|startup|pitch/)) r.tags.push('business');
        if (lower.match(/online|virtual|remote/)) r.tags.push('online');
        if (lower.match(/hybrid/)) r.tags.push('hybrid');
        if (lower.match(/offline|in.person/)) r.tags.push('offline');
        if (lower.match(/advanced|hard|expert/)) r.tags.push('advanced');
        if (lower.match(/beginner|easy|open/)) r.tags.push('beginner');
        if (r.tags.length === 0) r.tags = ['coding', 'open'];

        const orgM = text.match(/by\s+([A-Z][a-zA-Z]+)|from\s+([A-Z][a-zA-Z]+)/);
        if (orgM) r.organizer = (orgM[1] || orgM[2]).trim();

        if (!r.title) r.title = 'Untitled Competition';
        r.description = r.title + (r.prize ? ` — Prize: ${r.prize}.` : '') + (r.location ? ` Location: ${r.location}.` : '');
        
        return r;
    }

    // ADD TO PENDING QUEUE
    document.getElementById('addToPendingBtn').addEventListener('click', () => {
        const db = getDB();
