    // RENDER PENDING LIST
    function renderPendingList() {
        const db = getDB().filter(c => c.status === 'pending');
        const container = document.getElementById('pendingList');
        updatePendingCount();

        if (db.length === 0) {
            container.innerHTML = '<div class="empty-state"><i class="fa-solid fa-check-circle" style="color:#27AE60; font-size:24px;"></i><p>No items pending review</p></div>';
            return;
        }

        container.innerHTML = db.map(c => `
            <div class="pending-item">
                <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:8px;">
                    <h4>${c.title}</h4>
                    <span class="status-badge status-pending">Pending</span>
                </div>
                <p>${c.organizer} · ${c.prize || 'No prize'} · ${c.deadline || 'No deadline'}</p>
                <div style="margin-bottom:12px;">${c.tags.map(t => `<span class="pill-tag ${t}" style="font-size:10px; padding:2px 8px;">${t}</span>`).join(' ')}</div>
                <div class="pending-actions">
                    <button class="btn-approve" onclick="approveItem(${c.id})"><i class="fa-solid fa-check"></i> Approve & Post</button>
                    <button class="btn-reject" onclick="rejectItem(${c.id})"><i class="fa-solid fa-trash"></i> Reject</button>
                </div>
            </div>
        `).join('');
    }

    function approveItem(id) {
        const db = getDB();
        const item = db.find(c => c.id === id);
        if (item) {
            item.status = 'approved';
            saveDB(db);
            renderPendingList();
            renderLiveList();
            renderPublicCards(); // Refresh public view instantly
        }
    }

    function rejectItem(id) {
        let db = getDB();
        db = db.filter(c => c.id !== id);
        saveDB(db);
        renderPendingList();
    }

    // RENDER LIVE LIST
    function renderLiveList() {
        const db = getDB().filter(c => c.status === 'approved');
        const container = document.getElementById('liveList');

        if (db.length === 0) {
            container.innerHTML = '<div class="empty-state"><p>No live competitions yet</p></div>';
            return;
        }

        container.innerHTML = db.map(c => `
            <div class="pending-item" style="background:#D4EDDA;">
                <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:4px;">
                    <h4>${c.title}</h4>
                    <span class="status-badge status-approved">Live</span>
                </div>
                <p style="font-size:12px;">${c.organizer} · ${c.featured ? '⭐ Featured' : 'Standard'}</p>
                <div class="pending-actions" style="margin-top:12px;">
                    <button class="btn-reject" onclick="deleteLiveItem(${c.id})"><i class="fa-solid fa-trash"></i> Remove</button>
                </div>
            </div>
        `).join('');
    }

    function deleteLiveItem(id) {
        let db = getDB();
        db = db.filter(c => c.id !== id);
        saveDB(db);
        renderLiveList();
        renderPublicCards();
    }

    function updatePendingCount() {
        const count = getDB().filter(c => c.status === 'pending').length;
        document.getElementById('pendingCount').textContent = count;
    }

    // GEMINI API KEY SETUP
    if (!localStorage.getItem('klyrr_gemini_key')) {
        setTimeout(() => {
            const key = prompt('🔧 Setup: Paste your Gemini API key for AI extraction.\n\nGet it FREE at: https://aistudio.google.com/apikey\n\nLeave empty to use basic local parser.');
            if (key && key.trim()) localStorage.setItem('klyrr_gemini_key', key.trim());
        }, 2000);
    }
