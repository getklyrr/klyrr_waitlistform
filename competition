<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Klyrr Opportunities — Competitions</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --bg-light: #F9F6F0;
            --maroon-dark: #3F1522;
            --maroon-header: #4A1525;
            --gold: #C09E53;
            --text-dark: #3F1522;
            --text-muted: #7E6E65;
            --border-color: #E6E1DA;
            --tag-advanced-bg: #FFE5E5; --tag-advanced-text: #FF5C5C;
            --tag-hybrid-bg: #EAE5FF; --tag-hybrid-text: #7C5CFF;
            --tag-coding-bg: #F5EFE6; --tag-coding-text: #8A7E72;
            --tag-open-bg: #E2F5EA; --tag-open-text: #27AE60;
            --tag-science-bg: #F5EFE6; --tag-science-text: #8A7E72;
            --tag-design-bg: #FFF5E5; --tag-design-text: #D4850A;
            --tag-business-bg: #E5F0FF; --tag-business-text: #1B6BFF;
            --tag-online-bg: #E5F9FF; --tag-online-text: #00A5C8;
            --tag-offline-bg: #FFE5E5; --tag-offline-text: #D31D1D;
            --tag-beginner-bg: #E8F5E9; --tag-beginner-text: #2E7D32;
            --tag-intermediate-bg: #FFF8E1; --tag-intermediate-text: #F57F17;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            min-height: 100vh;
        }

        .hidden { display: none !important; }

        /* DASHBOARD HEADER */
        .dashboard-header {
            background-color: var(--maroon-header);
            color: #FFFFFF;
            padding: 40px 40px 30px 40px;
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .breadcrumbs-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .breadcrumbs {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.4);
        }

        .breadcrumbs a { color: rgba(255, 255, 255, 0.4); text-decoration: none; }
        .breadcrumbs .active { color: var(--gold); }

        .btn-back {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: #FFFFFF;
            padding: 6px 14px;
            border-radius: 8px;
            font-family: inherit;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .btn-back:hover { background: rgba(255, 255, 255, 0.15); }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .page-subtitle {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 24px;
        }

        .search-wrapper {
            position: relative;
            margin-bottom: 20px;
        }

        .search-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.4);
            font-size: 14px;
        }

        .search-input {
            width: 100%;
            background-color: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 14px 16px 14px 44px;
            color: #FFFFFF;
            font-family: inherit;
            font-size: 14px;
            outline: none;
        }

        .search-input::placeholder { color: rgba(255, 255, 255, 0.35); }

        .filter-tags-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .filter-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background-color: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.8);
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }

        .filter-btn.active {
            background-color: var(--gold);
            border-color: var(--gold);
            color: var(--maroon-dark);
            font-weight: 700;
        }

        /* CONTENT */
        .content-container {
            max-width: 1400px;
            margin: 24px auto;
            padding: 0 20px;
        }

        /* CARDS */
        .opportunity-card {
            background-color: #FFFFFF;
            border-radius: 16px;
            border: 1px solid var(--border-color);
            margin-bottom: 24px;
            overflow: hidden;
        }

        .featured-header {
            background-color: var(--maroon-dark);
            color: var(--gold);
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 8px 20px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .card-body {
            padding: 24px 24px 16px 24px;
        }

        .card-top-flex {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .company-name {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 4px;
            margin-bottom: 12px;
        }

        .opportunity-title {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--maroon-dark);
        }

        .bookmark-btn {
            background: none;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-dark);
            font-size: 13px;
            transition: all 0.2s;
        }
        .bookmark-btn:hover { border-color: var(--gold); color: var(--gold); }

        .pill-tags-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 24px;
        }

        .pill-tag {
            font-size: 11px;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 20px;
        }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }

        .detail-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

        .detail-icon {
            color: var(--text-muted);
            font-size: 14px;
            margin-top: 2px;
        }

        .detail-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: rgba(63, 21, 34, 0.4);
            margin-bottom: 2px;
        }

        .detail-value {
            font-size: 14px;
            font-weight: 700;
            color: var(--maroon-dark);
        }

        .location-row {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #A08E84;
            margin-bottom: 16px;
        }

        .card-description {
            font-size: 13px;
            color: var(--text-muted);
            line-height: 1.6;
            margin-bottom: 8px;
        }

        .bottom-meta-tags {
            display: flex;
            gap: 8px;
            margin-bottom: 8px;
        }

        .meta-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background-color: #F3EFF6;
            color: #8A7E8C;
            font-size: 11px;
            padding: 4px 10px;
            border-radius: 6px;
        }

        .card-action-bar {
            padding: 0 16px 16px 16px;
        }

        .card-apply-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background-color: var(--maroon-dark);
            color: #FFFFFF;
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            border: none;
            cursor: pointer;
            font-family: inherit;
            transition: opacity 0.2s;
        }
        .card-apply-btn:hover { opacity: 0.9; }

        /* FOOTER */
        .main-footer {
            text-align: center;
            padding: 40px 20px;
            border-top: 1px solid var(--border-color);
        }
        .admin-trigger {
            background: none; border: none; color: #D0C8C0; cursor: pointer; font-size: 14px;
        }

        /* ADMIN PANEL MODAL */
        .admin-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 100;
            display: flex; align-items: center; justify-content: center;
        }
        .admin-modal {
            background: #FFF; border-radius: 16px; width: 90%; max-width: 800px; max-height: 90vh;
            overflow-y: auto; position: relative;
        }
        .admin-header {
            background: var(--maroon-dark); color: white; padding: 20px 24px;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 10;
        }
        .admin-header h2 { font-family: 'Playfair Display', serif; font-size: 20px; }
        .admin-close { background: none; border: none; color: white; font-size: 20px; cursor: pointer; }
        .admin-body { padding: 24px; }
        
        .admin-tabs { display: flex; gap: 12px; border-bottom: 1px solid var(--border-color); margin-bottom: 24px; }
        .admin-tab {
            padding: 8px 0; font-weight: 600; font-size: 14px; border: none; background: none;
            color: var(--text-muted); cursor: pointer; border-bottom: 2px solid transparent;
        }
        .admin-tab.active { color: var(--maroon-dark); border-bottom-color: var(--gold); }

        .form-group { margin-bottom: 16px; }
        .form-label {
            display: block; font-size: 11px; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.5px; color: rgba(63, 21, 34, 0.5); margin-bottom: 6px;
        }
        .form-input, .form-textarea {
            width: 100%; border: 1px solid var(--border-color); border-radius: 8px;
            padding: 10px 12px; font-family: inherit; font-size: 14px; outline: none;
            transition: border-color 0.2s;
        }
        .form-input:focus, .form-textarea:focus { border-color: var(--gold); }
        .form-textarea { resize: vertical; min-height: 120px; }
        
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        
        .btn-extract {
            background: var(--maroon-dark); color: white; border: none; padding: 12px 24px;
            border-radius: 8px; font-family: inherit; font-weight: 600; cursor: pointer;
            display: inline-flex; align-items: center; gap: 8px; font-size: 14px;
        }
        .btn-extract:hover { opacity: 0.9; }
        
        .btn-approve {
            background: #27AE60; color: white; border: none; padding: 8px 16px;
            border-radius: 8px; font-family: inherit; font-weight: 600; cursor: pointer; font-size: 13px;
        }
        .btn-reject {
            background: #FF5C5C; color: white; border: none; padding: 8px 16px;
            border-radius: 8px; font-family: inherit; font-weight: 600; cursor: pointer; font-size: 13px;
        }

        .pending-item {
            border: 1px solid var(--border-color); border-radius: 12px; padding: 16px;
            margin-bottom: 12px; background: #FAFAFA;
        }
        .pending-item h4 { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
        .pending-item p { font-size: 13px; color: var(--text-muted); margin-bottom: 12px; }
        .pending-actions { display: flex; gap: 8px; }

        .status-badge {
            display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 10px;
            font-weight: 700; text-transform: uppercase;
        }
        .status-pending { background: #FFF3CD; color: #856404; }
        .status-approved { background: #D4EDDA; color: #155724; }

        .empty-state {
            text-align: center; padding: 40px 20px; color: var(--text-muted);
        }

        @media(max-width: 768px) {
            .dashboard-header { padding: 24px 20px; }
            .details-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
            .form-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- MAIN PUBLIC VIEW -->
    <div>
        <header class="dashboard-header">
            <div class="header-container">
                <div class="breadcrumbs-wrapper">
                    <div class="breadcrumbs">
                        <a href="/"><i class="fa-solid fa-wand-magic-sparkles" style="font-size:10px;"></i> Klyrr</a>
                        <span>&times;</span>
                        <span class="active">Opportunities</span>
                    </div>
                    <a href="/" class="btn-back">
                        <i class="fa-solid fa-chevron-left"></i> Back
                    </a>
                </div>
                
                <h2 class="page-title">Competitions & Hackathons</h2>
                <p id="pageSubtitle" class="page-subtitle">Loading opportunities...</p>
                
                <div class="search-wrapper">
                    <i class="fa-solid fa-magnifying-glass search-icon"></i>
                    <input type="text" id="searchInput" class="search-input" placeholder="Search competitions, skills, or organizers...">
                </div>

                <div id="filterRow" class="filter-tags-row">
                    <button class="filter-btn active" data-filter="all"><i class="fa-solid fa-grip"></i> All</button>
                    <button class="filter-btn" data-filter="coding"><i class="fa-solid fa-code"></i> Coding</button>
                    <button class="filter-btn" data-filter="design"><i class="fa-solid fa-palette"></i> Design</button>
                    <button class="filter-btn" data-filter="science"><i class="fa-solid fa-flask"></i> Science</button>
                    <button class="filter-btn" data-filter="business"><i class="fa-solid fa-briefcase"></i> Business</button>
                </div>
            </div>
        </header>

        <main id="cardsContainer" class="content-container">
            <!-- Rendered dynamically -->
        </main>

        <footer class="main-footer">
            <button id="adminTriggerBtn" class="admin-trigger"><i class="fa-solid fa-lock"></i></button>
        </footer>
    </div>

    <!-- ADMIN PANEL MODAL -->
    <div id="adminOverlay" class="admin-overlay hidden">
        <div class="admin-modal">
            <div class="admin-header">
                <h2><i class="fa-solid fa-shield-halved"></i> Admin Panel</h2>
                <button id="adminCloseBtn" class="admin-close"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="admin-body">
                <!-- Login State -->
                <div id="adminLogin" class="text-center py-8">
                    <p style="margin-bottom: 16px; color: var(--text-muted);">Enter admin password to continue</p>
                    <input type="password" id="adminPasswordInput" class="form-input" style="max-width: 300px; margin: 0 auto;" placeholder="Password">
                    <button id="adminLoginBtn" class="btn-extract" style="margin-top: 12px; width: 100%; max-width: 300px; justify-content: center;">
                        <i class="fa-solid fa-right-to-bracket"></i> Login
                    </button>
                </div>

                <!-- Logged In State -->
                <div id="adminDashboard" class="hidden">
                    <div class="admin-tabs">
                        <button class="admin-tab active" data-tab="paste">Paste & Extract</button>
                        <button class="admin-tab" data-tab="pending">Review Queue (<span id="pendingCount">0</span>)</button>
                        <button class="admin-tab" data-tab="manage">Manage Live</button>
                    </div>

                    <!-- TAB 1: PASTE & EXTRACT -->
                    <div id="tabPaste" class="admin-tab-content">
                        <div class="form-group">
                            <label class="form-label">Paste WhatsApp Message</label>
                            <textarea id="whatsappInput" class="form-textarea" rows="6" placeholder="🔥 *Flipkart GRiD 6.0* is here!
💰 Prize: ₹5,00,000 + PPO
📅 Deadline: June 30, 2025
📍 Bangalore (Finals)
🔗 Register: https://link.com..."></textarea>
                        </div>
                        <button id="extractBtn" class="btn-extract">
                            <i class="fa-solid fa-wand-magic-sparkles"></i> Extract with AI
                        </button>

                        <div id="extractedForm" class="hidden" style="margin-top: 24px; border-top: 1px solid var(--border-color); padding-top: 24px;">
                            <p style="font-size: 12px; color: var(--gold); font-weight: 700; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">
                                <i class="fa-solid fa-check-circle"></i> AI Extracted — Review & Edit
                            </p>
                            <div class="form-grid">
                                <div class="form-group"><label class="form-label">Title</label><input type="text" id="exTitle" class="form-input"></div>
                                <div class="form-group"><label class="form-label">Organizer</label><input type="text" id="exOrganizer" class="form-input"></div>
                                <div class="form-group"><label class="form-label">Deadline</label><input type="text" id="exDeadline" class="form-input" placeholder="e.g. Jun 30, 2025"></div>
                                <div class="form-group"><label class="form-label">Prize</label><input type="text" id="exPrize" class="form-input"></div>
                                <div class="form-group"><label class="form-label">Location</label><input type="text" id="exLocation" class="form-input"></div>
                                <div class="form-group"><label class="form-label">Timeline</label><input type="text" id="exTimeline" class="form-input" placeholder="e.g. Aug-Sep 2025"></div>
                                <div class="form-group"><label class="form-label">Team Size</label><input type="text" id="exTeamSize" class="form-input" placeholder="e.g. 2-3 members"></div>
                                <div class="form-group"><label class="form-label">Apply Link</label><input type="url" id="exApplyUrl" class="form-input"></div>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Tags (comma separated: coding, advanced, hybrid, science, design, business, open, beginner, intermediate, online, offline)</label>
                                <input type="text" id="exTags" class="form-input" placeholder="e.g. coding, advanced, hybrid">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Description</label>
                                <textarea id="exDescription" class="form-textarea" rows="3"></textarea>
                            </div>
                            <div style="display: flex; gap: 12px; align-items: center; margin-top: 16px;">
                                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px; font-weight: 600;">
                                    <input type="checkbox" id="exFeatured" style="width: 16px; height: 16px; accent-color: var(--gold);"> Mark as Featured
                                </label>
                            </div>
                            <button id="addToPendingBtn" class="btn-extract" style="margin-top: 20px; background: #27AE60;">
                                <i class="fa-solid fa-paper-plane"></i> Add to Review Queue
                            </button>
                        </div>
                    </div>

                    <!-- TAB 2: PENDING REVIEW -->
                    <div id="tabPending" class="admin-tab-content hidden">
                        <div id="pendingList"></div>
                    </div>

                    <!-- TAB 3: MANAGE LIVE -->
                    <div id="tabManage" class="admin-tab-content hidden">
                        <div id="liveList"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
    // ==========================================
    // DATA LAYER (LOCAL STORAGE - FREE DB)
    // ==========================================
    const DB_KEY = 'klyrr_competitions';
    
    function getDB() {
        const data = localStorage.getItem(DB_KEY);
        if (!data) {
            // Seed with initial data
            const seed = [
                {
                    id: 1, status: 'approved', featured: true,
                    title: 'Flipkart GRiD 6.0', organizer: 'Flipkart',
                    tags: ['advanced', 'hybrid', 'coding'],
                    deadline: 'Jun 30, 2025', timeline: 'Aug–Sep 2025',
                    prize: '₹5,00,000 + PPO offers', teamSize: '2–3 members',
                    location: 'Bangalore (Finals)', 
                    description: 'E-commerce and technology challenge by Flipkart. Shortlisted teams get pre-placement interview opportunities. Highly competitive.',
                    applyUrl: '#', metaTags: ['E-commerce', 'PPO', 'Industry']
                },
                {
                    id: 2, status: 'approved', featured: true,
                    title: 'NASA Space Apps Challenge', organizer: 'NASA',
                    tags: ['open', 'hybrid', 'science'],
                    deadline: 'Oct 4, 2025', timeline: 'Oct 2025',
                    prize: 'Global Recognition & NASA Swag', teamSize: 'Up to 5 members',
                    location: 'Global (200+ cities)',
                    description: 'NASA\'s flagship international hackathon tackling real-world challenges on Earth and in space. Open to all skill levels.',
                    applyUrl: '#', metaTags: ['Space', 'Global', 'Research']
                }
            ];
            localStorage.setItem(DB_KEY, JSON.stringify(seed));
            return seed;
        }
        return JSON.parse(data);
    }

    function saveDB(data) {
        localStorage.setItem(DB_KEY, JSON.stringify(data));
    }

    // ==========================================
    // PUBLIC FRONTEND RENDERING
    // ==========================================
    let currentFilter = 'all';
    let searchQuery = '';

    function renderPublicCards() {
        const db = getDB().filter(c => c.status === 'approved');
        const container = document.getElementById('cardsContainer');
        
        let filtered = db;
        if (currentFilter !== 'all') {
            filtered = db.filter(c => c.tags.includes(currentFilter));
        }
        if (searchQuery) {
            const q = searchQuery.toLowerCase();
            filtered = filtered.filter(c => 
                c.title.toLowerCase().includes(q) || 
                c.organizer.toLowerCase().includes(q) || 
                c.tags.some(t => t.includes(q)) ||
                c.description.toLowerCase().includes(q)
            );
        }

        document.getElementById('pageSubtitle').textContent = `${filtered.length} opportunities · Local & Global`;

        if (filtered.length === 0) {
            container.innerHTML = '<div class="empty-state"><i class="fa-solid fa-search" style="font-size:24px; margin-bottom:8px;"></i><p>No competitions found</p></div>';
            return;
        }

        // Sort: featured first
        filtered.sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0));

        let html = '';
        filtered.forEach(c => {
            const tagsHtml = c.tags.map(t => {
                const label = t.charAt(0).toUpperCase() + t.slice(1);
                return `<span class="pill-tag ${t}">${label}</span>`;
            }).join('');

            const metaHtml = (c.metaTags || []).map(m => `<span class="meta-tag"><i class="fa-solid fa-tag"></i> ${m}</span>`).join('');

            html += `
            <div class="opportunity-card">
                ${c.featured ? `<div class="featured-header"><i class="fa-solid fa-thumbtack"></i> Featured</div>` : ''}
                <div class="card-body">
                    <div class="card-top-flex">
                        <div>
                            <h3 class="opportunity-title">${c.title}</h3>
                            <p class="company-name">${c.organizer}</p>
                        </div>
                        <button class="bookmark-btn" onclick="this.querySelector('i').classList.toggle('fa-regular'); this.querySelector('i').classList.toggle('fa-solid');">
                            <i class="fa-regular fa-bookmark"></i>
                        </button>
                    </div>
